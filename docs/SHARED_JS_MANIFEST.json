  "deliberately_excluded": [
    {
      "path": "deviceCapabilityStore.js",
      "reason": "Imports NativeModules. The store itself is small and iOS-specific UUID persistence (Keychain) differs from Android's SharedPreferences — reimplement in js/ios/."
    },
    {
      "path": "notificationStore.js",
      "reason": "Imports NativeModules and calls FCM-specific paths. iOS uses APNs; rewrite in js/ios/."
    },
    {
      "path": "hooks/useMicAmplitude.js — RECLASSIFIED (now vendored)",
      "reason": "Originally excluded because it reads MicAmplitudeModule from NativeModules. iOS Swift port implements the same module name + event shape, so the Android JS works as-is. Android-only PermissionsAndroid path is guarded with Platform.OS !== 'android'."
    },
    {
      "path": "hooks/useMultiplayerSync.js — RECLASSIFIED (now vendored)",
      "reason": "Originally excluded for WAMP bridge concerns. realtimeService.js abstracts WAMP through DeviceEventEmitter on both platforms; the hook itself is platform-agnostic and only depends on realtimeService + gamesApi (both vendored)."
    },
    {
      "path": "hooks/useSpeechRecognition.js — RECLASSIFIED (now vendored)",
      "reason": "Originally excluded for SFSpeechRecognizer differences. iOS Swift SpeechRecognizerModule implements the same NativeModule contract. ActivityStarterModule fallbacks are guarded with truthy checks and no-op on iOS where the module doesn't exist."
    },
    {
      "path": "components/**",
      "reason": "Sync deferred. Many components are cross-platform but the kids-learning + agentic-overlay + signup screens have native imports. Per-component classification + copy is a follow-up sync pass."
    },
    {
      "path": "android/**",
      "reason": "All Java/Kotlin. iOS native modules live in ios/NunbaCompanion/Modules/."
    },
    {
      "path": "Wear OS source",
      "reason": "Apple Watch is a separate WatchOS project. Different SDK, different paradigm. Out of scope for this port."
    },
    {
      "path": "Android TV source",
      "reason": "tvOS is a separate target. Out of scope for this port."
    },
    {
      "path": "OpenGL ES 3.0 avatar renderer (glSurface/)",
      "reason": "Will need a Metal port. Future phase."
    }
  ],
  "policy": {
    "edits_to_synced_files": "FORBIDDEN. js/shared/ is vendored — any edit gets clobbered on the next sync. If iOS needs to diverge, copy the file out of shared/ into js/ios/ first.",
    "adding_new_synced_files": "1) Add the path to this manifest. 2) Run scripts/sync-from-android.sh. 3) Commit both the manifest update and the new file in one commit.",
    "removing_synced_files": "Remove from manifest, delete from js/shared/, commit both. Don't leave orphans."
  }
}
